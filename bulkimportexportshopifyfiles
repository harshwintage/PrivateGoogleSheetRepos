  function onError(err) {
    document.getElementById('results').innerHTML = '<div class="error-box">❌ ' + escapeHtml(err.message) + '</div><button class="btn btn-analyze" onclick="analyze()">🔍 Try Again</button>';
  }
  
  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>

