// ── ANALYZE PUSH TAB (called from push sidebar) ─────────────
// Compares Push tab to Data tab and finds differences

function analyzePushChanges() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const pushSheet = ss.getSheetByName('Push');
  const dataSheet = ss.getSheetByName('Data');
  
  if (!pushSheet) throw new Error('Push tab not found. Copy rows from Data tab into a sheet named "Push".');
  if (!dataSheet) throw new Error('Data tab not found. Run a Pull first.');
  
  // Read headers and data from both sheets
  const pushData = pushSheet.getDataRange().getValues();
  const dataData = dataSheet.getDataRange().getValues();
  
  if (pushData.length < 2) throw new Error('Push tab is empty (no data rows).');
  if (dataData.length < 2) throw new Error('Data tab is empty. Run a Pull first.');
  
  const pushHeaders = pushData[0].map(h => h.toString().trim());
  const dataHeaders = dataData[0].map(h => h.toString().trim());
  
  // Verify Push tab has Product ID column
  const pushIdCol = pushHeaders.indexOf('Product ID');
  if (pushIdCol === -1) throw new Error('Push tab must have a "Product ID" column (copy rows from Data tab).');
  
  const dataIdCol = dataHeaders.indexOf('Product ID');
  if (dataIdCol === -1) throw new Error('Data tab is missing "Product ID" column. Re-pull.');
  
  // Build a lookup of Data tab by Product ID
  const dataLookup = {};
  for (let i = 1; i < dataData.length; i++) {
    const id = dataData[i][dataIdCol].toString().trim();
    if (id) {
      const rowObj = {};
      dataHeaders.forEach((h, col) => { rowObj[h] = dataData[i][col]; });
      dataLookup[id] = rowObj;
    }
  }
  
  // Find pushable columns — these are fields the API can update
  const pushableFields = ['Title', 'Tags', 'Category ID', 'Vendor', 'Product Type', 'Status', 'SEO Title', 'SEO Description', 'Description (HTML)'];
  // Also any MF: columns
  const mfColumns = pushHeaders.filter(h => h.startsWith('MF: '));
  const allPushable = [...pushableFields, ...mfColumns];
  
  // Read-only columns — pulled but can't be pushed back
  const readOnlyFields = ['Product ID', 'Handle', 'SKU', 'Category Name', 'Category Full Name', 'Image 1', 'Image 2', 'Image 3', 'Variant Count', 'Variants (JSON)'];
  
  // Compare each row in Push tab to Data tab
  const changes = [];
  
  for (let i = 1; i < pushData.length; i++) {
    const productId = pushData[i][pushIdCol].toString().trim();
    if (!productId) continue;
    
    const handle = pushData[i][pushHeaders.indexOf('Handle')] || '';
    const title = pushData[i][pushHeaders.indexOf('Title')] || '';
    const dataRow = dataLookup[productId];
    
    const rowChanges = [];
    
    allPushable.forEach(field => {
      const pushCol = pushHeaders.indexOf(field);
      if (pushCol === -1) return; // Field not in Push tab
      
      const pushVal = pushData[i][pushCol]?.toString().trim() || '';
      const dataVal = dataRow ? (dataRow[field]?.toString().trim() || '') : '';
      
      if (pushVal !== dataVal) {
        rowChanges.push({
          field: field,
          oldValue: dataVal,
          newValue: pushVal
        });
      }
    });
    
    if (rowChanges.length > 0) {
      changes.push({
        productId: productId,
        handle: handle.toString(),
        title: title.toString(),
        rowNum: i + 1,
        changes: rowChanges
      });
    }
  }
  
  // Get pull timestamp from Data tab
  const pullTimestamp = dataSheet.getRange(1, dataHeaders.length + 3).getValue();
  
  return {
    totalPushRows: pushData.length - 1,
    productsWithChanges: changes.length,
    totalChanges: changes.reduce((sum, c) => sum + c.changes.length, 0),
    pullTimestamp: pullTimestamp ? pullTimestamp.toString() : 'Unknown',
    changes: changes,
    pushableColumns: allPushable.filter(f => pushHeaders.includes(f)),
    readOnlyColumns: readOnlyFields.filter(f => pushHeaders.includes(f)),
    ignoredEdits: [] // populated below
  };
}

// ── EXECUTE PUSH (CHUNKED) ──────────────────────────────────
// Processes in batches of 200 to stay within Apps Script's 6-min limit.
// Uses ScriptProperties to track progress across runs.
// Auto-chains via time-based triggers if more batches remain.

var PUSH_BATCH_SIZE = 200;

function executePush(isDryRun) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const analysis = analyzePushChanges();
  
  if (analysis.productsWithChanges === 0) {
    return { success: true, message: 'No changes detected.', results: [] };
  }
  
  if (isDryRun) {
    return { success: true, message: 'Dry run complete.', dryRun: true, analysis: analysis };
  }
  
  // Save all changes to ScriptProperties so chunked runs can access them
  const props = PropertiesService.getScriptProperties();
  props.setProperty('PUSH_CHANGES', JSON.stringify(analysis.changes));
  props.setProperty('PUSH_INDEX', '0');
  props.setProperty('PUSH_RESULTS', JSON.stringify([]));
  props.setProperty('PUSH_TOTAL', analysis.changes.length.toString());
  props.setProperty('PUSH_RUNNING', 'true');
  
  // Run the first batch
  const batchResult = executePushBatch_();
  
  return batchResult;
}

function executePushBatch_() {
  const props = PropertiesService.getScriptProperties();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  
  const changes = JSON.parse(props.getProperty('PUSH_CHANGES') || '[]');
  let startIndex = parseInt(props.getProperty('PUSH_INDEX') || '0');
  let results = JSON.parse(props.getProperty('PUSH_RESULTS') || '[]');
  const total = parseInt(props.getProperty('PUSH_TOTAL') || '0');
  
  if (changes.length === 0 || startIndex >= changes.length) {
    finalizePush_();
    return { success: true, message: 'No more products to push.', results: results };
  }
  
  const token = getAccessToken_();
  const config = getConfig_();
  
  const endIndex = Math.min(startIndex + PUSH_BATCH_SIZE, changes.length);
  Logger.log(`📤 Push batch: products ${startIndex + 1} to ${endIndex} of ${changes.length}`);
  
  for (let i = startIndex; i < endIndex; i++) {
    const product = changes[i];
    try {
      const mutation = buildUpdateMutation_(product);
      const result = shopifyGraphQL_(token, config.shopDomain, mutation.query, mutation.variables);
      
      const userErrors = result.data?.productUpdate?.userErrors || [];
      
      if (userErrors.length > 0) {
        results.push({
          productId: product.productId,
          handle: product.handle,
          status: '❌ Error',
          details: userErrors.map(e => `${e.field}: ${e.message}`).join('; ')
        });
      } else {
        results.push({
          productId: product.productId,
          handle: product.handle,
          status: '✅ Updated',
          details: product.changes.map(c => c.field).join(', ')
        });
      }
      
      Utilities.sleep(500);
      
    } catch (e) {
      results.push({
        productId: product.productId,
        handle: product.handle,
        status: '❌ Failed',
        details: e.message
      });
    }
  }
  
  // Save progress
  props.setProperty('PUSH_INDEX', endIndex.toString());
  props.setProperty('PUSH_RESULTS', JSON.stringify(results));
  
  // Check if more batches needed
  if (endIndex < changes.length) {
    // Schedule next batch in 10 seconds via trigger
    Logger.log(`⏳ ${changes.length - endIndex} products remaining. Scheduling next batch...`);
    
    // Clean up old triggers first
    cleanPushTriggers_();
    
    // Create a new trigger to continue
    ScriptApp.newTrigger('continuePush')
      .timeBased()
      .after(10 * 1000) // 10 seconds
      .create();
    
    // Write intermediate results
    writePushResults_(ss, results);
    logAction_(ss, 'PUSH (batch)', `${endIndex} of ${changes.length} processed so far`, '🔄 In progress');
    
    return { 
      success: true, 
      message: `Batch complete: ${endIndex} of ${changes.length} products processed. Next batch auto-scheduled.`,
      results: results,
      inProgress: true,
      processed: endIndex,
      total: changes.length
    };
  } else {
    // All done
    finalizePush_();
    return {
      success: true,
      message: `Push complete. ${results.filter(r => r.status.includes('✅')).length} updated, ${results.filter(r => r.status.includes('❌')).length} failed.`,
      results: results,
      inProgress: false
    };
  }
}

// Called automatically by the time trigger for subsequent batches
function continuePush() {
  cleanPushTriggers_();
  
  const props = PropertiesService.getScriptProperties();
  if (props.getProperty('PUSH_RUNNING') !== 'true') return;
  
  executePushBatch_();
}

function finalizePush_() {
  const props = PropertiesService.getScriptProperties();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const results = JSON.parse(props.getProperty('PUSH_RESULTS') || '[]');
  
  const successCount = results.filter(r => r.status.includes('✅')).length;
  const failCount = results.filter(r => r.status.includes('❌')).length;
  
  logAction_(ss, 'PUSH (complete)', `${successCount} succeeded, ${failCount} failed out of ${results.length} products`, 
    failCount === 0 ? '✅ Success' : '⚠️ Partial');
  
  writePushResults_(ss, results);
  
  // Clean up
  props.deleteProperty('PUSH_CHANGES');
  props.deleteProperty('PUSH_INDEX');
  props.deleteProperty('PUSH_RESULTS');
  props.deleteProperty('PUSH_TOTAL');
  props.setProperty('PUSH_RUNNING', 'false');
  
  cleanPushTriggers_();
  
  Logger.log(`✅ Push finalized. ${successCount} updated, ${failCount} failed.`);
}

function cleanPushTriggers_() {
  ScriptApp.getProjectTriggers().forEach(trigger => {
    if (trigger.getHandlerFunction() === 'continuePush') {
      ScriptApp.deleteTrigger(trigger);
    }
  });
}

// Check push status (called from sidebar)
function getPushStatus() {
  const props = PropertiesService.getScriptProperties();
  const running = props.getProperty('PUSH_RUNNING') === 'true';
  const index = parseInt(props.getProperty('PUSH_INDEX') || '0');
  const total = parseInt(props.getProperty('PUSH_TOTAL') || '0');
  const results = JSON.parse(props.getProperty('PUSH_RESULTS') || '[]');
  
  return { running, processed: index, total, results };
}

// Cancel an in-progress push
function cancelPush() {
  finalizePush_();
  return { success: true, message: 'Push cancelled.' };
}

// ── BUILD UPDATE MUTATION ───────────────────────────────────

function buildUpdateMutation_(product) {
  const productInput = {
    id: product.productId
  };
  
  const metafields = [];
  
  product.changes.forEach(change => {
    if (change.field === 'Title') {
      productInput.title = change.newValue;
    }
    else if (change.field === 'Tags') {
      // Tags are comma-separated in the sheet, need to be an array
      productInput.tags = change.newValue.split(',').map(t => t.trim()).filter(t => t);
    }
    else if (change.field === 'Category ID') {
      productInput.category = change.newValue;
    }
    else if (change.field === 'Vendor') {
      productInput.vendor = change.newValue;
    }
    else if (change.field === 'Product Type') {
      productInput.productType = change.newValue;
    }
    else if (change.field === 'Status') {
      productInput.status = change.newValue.toUpperCase();
    }
    else if (change.field === 'Description (HTML)') {
      productInput.descriptionHtml = change.newValue;
    }
    else if (change.field === 'SEO Title') {
      if (!productInput.seo) productInput.seo = {};
      productInput.seo.title = change.newValue;
    }
    else if (change.field === 'SEO Description') {
      if (!productInput.seo) productInput.seo = {};
      productInput.seo.description = change.newValue;
    }
    else if (change.field.startsWith('MF: ')) {
      // Metafield: "MF: namespace.key"
      const fullKey = change.field.replace('MF: ', '');
      const dotIndex = fullKey.indexOf('.');
      const namespace = fullKey.substring(0, dotIndex);
      const key = fullKey.substring(dotIndex + 1);
      
      metafields.push({
        namespace: namespace,
        key: key,
        value: change.newValue,
        type: 'single_line_text_field' // Default — will be overridden for existing metafields
      });
    }
  });
  
  if (metafields.length > 0) {
    productInput.metafields = metafields;
  }
  
  const query = `
    mutation UpdateProduct($product: ProductInput!) {
      productUpdate(input: $product) {
        product {
          id
          title
          tags
        }
        userErrors {
          field
          message
        }
      }
    }
  `;
  
  return { query, variables: { product: productInput } };
}

// ── WRITE PUSH RESULTS ──────────────────────────────────────

function writePushResults_(ss, results) {
  let sheet = ss.getSheetByName('Push Results');
  if (!sheet) sheet = ss.insertSheet('Push Results');
  sheet.clear();
  
  const headers = ['Timestamp', 'Product ID', 'Handle', 'Status', 'Details'];
  sheet.getRange(1, 1, 1, headers.length).setValues([headers]).setFontWeight('bold').setBackground('#e8e8e8');
  
  const now = new Date();
  const rows = results.map(r => [now, r.productId, r.handle, r.status, r.details]);
  if (rows.length > 0) {
    sheet.getRange(2, 1, rows.length, headers.length).setValues(rows);
  }
  
  for (let i = 1; i <= headers.length; i++) sheet.autoResizeColumn(i);
}

// ── DRY RUN FROM MENU ──────────────────────────────────────

function dryRunPush() {
  try {
    const result = executePush(true);
    const a = result.analysis;
    
    let msg = `DRY RUN RESULTS\n\n`;
    msg += `Push tab rows: ${a.totalPushRows}\n`;
    msg += `Products with changes: ${a.productsWithChanges}\n`;
    msg += `Total field changes: ${a.totalChanges}\n`;
    msg += `Data was pulled at: ${a.pullTimestamp}\n\n`;
    
    if (a.changes.length > 0) {
      msg += `CHANGES DETECTED:\n\n`;
      a.changes.slice(0, 10).forEach(c => {
        msg += `${c.handle}:\n`;
        c.changes.forEach(ch => {
          const oldVal = ch.oldValue.substring(0, 30) || '(empty)';
          const newVal = ch.newValue.substring(0, 30) || '(empty)';
          msg += `  ${ch.field}: "${oldVal}" → "${newVal}"\n`;
        });
        msg += '\n';
      });
      if (a.changes.length > 10) {
        msg += `... and ${a.changes.length - 10} more products.\n`;
      }
    }
    
    SpreadsheetApp.getUi().alert(msg);
  } catch (e) {
    SpreadsheetApp.getUi().alert('❌ ' + e.message);
  }
}

