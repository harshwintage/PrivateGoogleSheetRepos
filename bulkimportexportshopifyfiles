  body { font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', sans-serif; font-size: 13px; color: #1a1a1a; padding: 16px; background: #fff; }
  
  h2 { font-size: 16px; margin-bottom: 12px; color: #1a1a1a; }
  h3 { font-size: 13px; font-weight: 600; margin: 16px 0 8px 0; color: #555; text-transform: uppercase; letter-spacing: 0.5px; }
  
  .loading { text-align: center; padding: 40px 0; color: #888; }
  .spinner { display: inline-block; width: 24px; height: 24px; border: 3px solid #e0e0e0; border-top-color: #333; border-radius: 50%; animation: spin 0.8s linear infinite; }
  @keyframes spin { to { transform: rotate(360deg); } }
  
  .section { margin-bottom: 16px; border: 1px solid #e5e5e5; border-radius: 8px; overflow: hidden; }
  .section-header { padding: 10px 12px; background: #f8f8f8; font-weight: 600; font-size: 12px; color: #555; text-transform: uppercase; letter-spacing: 0.5px; cursor: pointer; display: flex; justify-content: space-between; align-items: center; }
  .section-header:hover { background: #f0f0f0; }
  .section-header .arrow { transition: transform 0.2s; }
  .section-header.collapsed .arrow { transform: rotate(-90deg); }
  .section-body { padding: 8px 12px; max-height: 200px; overflow-y: auto; }
  .section-body.collapsed { display: none; }
  
  .check-item { display: flex; align-items: center; padding: 4px 0; }
  .check-item label { margin-left: 6px; flex: 1; cursor: pointer; }
  .check-item .count { color: #999; font-size: 11px; margin-left: 4px; }
  .check-item input[type=checkbox] { cursor: pointer; }
  
  .select-all { font-size: 11px; color: #0066cc; cursor: pointer; text-decoration: underline; }
  
  .btn { display: block; width: 100%; padding: 12px; border: none; border-radius: 8px; font-size: 14px; font-weight: 600; cursor: pointer; margin-top: 8px; }
  .btn-primary { background: #1a1a1a; color: #fff; }
  .btn-primary:hover { background: #333; }
  .btn-primary:disabled { background: #ccc; cursor: not-allowed; }
  .btn-secondary { background: #f0f0f0; color: #333; }
  .btn-secondary:hover { background: #e5e5e5; }
  
  .preview-box { margin-top: 12px; padding: 12px; background: #f9f9f9; border-radius: 8px; border: 1px solid #e5e5e5; font-size: 12px; max-height: 300px; overflow-y: auto; }
  .preview-box .field { margin-bottom: 4px; }
  .preview-box .field-label { font-weight: 600; color: #555; }
  .preview-box .field-value { color: #1a1a1a; word-break: break-all; }
  
  .status-bar { position: sticky; bottom: 0; background: #fff; padding: 12px 0 0 0; border-top: 1px solid #e5e5e5; margin-top: 16px; }
  .status-text { text-align: center; font-size: 12px; color: #888; margin-bottom: 8px; }
  
  .tag { display: inline-block; padding: 2px 8px; background: #f0f0f0; border-radius: 12px; font-size: 11px; margin: 2px; }
</style>
</head>
<body>

<div id="loading" class="loading">
  <div class="spinner"></div>
  <p style="margin-top:12px">Scanning your store...</p>
  <p style="font-size:11px; color:#aaa; margin-top:4px">Fetching product types, tags, vendors, metafields</p>
</div>

<div id="main" style="display:none">
  <h2>Pull Products</h2>
  <p style="font-size:12px; color:#888; margin-bottom:16px;">Select your filters and fields, then pull.</p>
  
  <!-- FILTERS -->
  <div class="section">
    <div class="section-header" onclick="toggleSection(this)">
      🔍 Filters <span class="arrow">▼</span>
    </div>
    <div class="section-body">
      
      <!-- Status -->
      <h3>Status</h3>
      <div id="statusFilters"></div>
      
      <!-- Product Type -->
      <h3>Product Type <span class="select-all" onclick="toggleAll('ptFilter')">toggle all</span></h3>
      <div id="productTypeFilters"></div>
      
      <!-- Vendor -->
      <h3>Vendor <span class="select-all" onclick="toggleAll('vendorFilter')">toggle all</span></h3>
      <div id="vendorFilters"></div>
      
      <!-- Tags -->
      <h3>Tags <span class="select-all" onclick="toggleAll('tagFilter')">toggle all</span></h3>
      <div id="tagFilters" style="max-height:150px; overflow-y:auto;"></div>
    </div>
  </div>
  
  <!-- FIELDS -->
  <div class="section">
    <div class="section-header" onclick="toggleSection(this)">
      📋 Fields to Pull <span class="arrow">▼</span>
    </div>
    <div class="section-body">
      <div id="fieldSelectors"></div>
    </div>
  </div>
  
  <!-- METAFIELDS -->
  <div class="section">
    <div class="section-header" onclick="toggleSection(this)">
      🏷️ Metafields <span class="select-all" onclick="event.stopPropagation(); toggleAll('mfKey')" style="margin-left:auto; margin-right:8px;">toggle all</span> <span class="arrow">▼</span>
    </div>
    <div class="section-body" id="metafieldSelectors" style="max-height:250px; overflow-y:auto;"></div>
  </div>
  
  <!-- PREVIEW -->
  <button class="btn btn-secondary" onclick="loadPreview()">👁️ Preview Sample Product</button>
  <div id="previewArea"></div>
  
  <!-- ACTIONS -->
  <div class="status-bar">
    <div class="status-text" id="statusText">Ready</div>
    <button class="btn btn-primary" id="pullBtn" onclick="executePull()">📥 Pull Products</button>
  </div>
</div>

<script>
  let storeData = null;
  
  // ── INIT ──
  google.script.run
    .withSuccessHandler(onMetadataLoaded)
    .withFailureHandler(onError)
    .fetchStoreMetadata();
  
  function onMetadataLoaded(data) {
    storeData = data;
    document.getElementById('loading').style.display = 'none';
    document.getElementById('main').style.display = 'block';
    
    // Render status filters
    renderCheckboxes('statusFilters', data.statuses, 'statusFilter', true);
    
    // Render product type filters
    renderCheckboxes('productTypeFilters', data.productTypes, 'ptFilter', false);
    
    // Render vendor filters
    renderCheckboxes('vendorFilters', data.vendors, 'vendorFilter', false);
    
    // Render tag filters
    renderCheckboxes('tagFilters', data.tags, 'tagFilter', false);
    
    // Render field selectors
    renderFieldSelectors();
    
    // Render metafield selectors
    renderCheckboxes('metafieldSelectors', data.metafieldKeys, 'mfKey', true);
    
    document.getElementById('statusText').textContent = data.totalProducts + ' products in store';
  }
  
  function onError(err) {
    document.getElementById('loading').innerHTML = '<p style="color:red">❌ ' + err.message + '</p>';
  }
  
  // ── RENDER CHECKBOXES ──
  function renderCheckboxes(containerId, items, namePrefix, checkedByDefault) {
    const container = document.getElementById(containerId);
    if (!items || items.length === 0) {
      container.innerHTML = '<p style="color:#aaa; font-size:12px;">None found</p>';
      return;
    }
    
    container.innerHTML = items.map((item, i) => {
      const checked = checkedByDefault ? 'checked' : '';
      const id = namePrefix + '_' + i;
      return '<div class="check-item">' +
        '<input type="checkbox" id="' + id + '" name="' + namePrefix + '" value="' + escapeHtml(item.name) + '" ' + checked + '>' +
        '<label for="' + id + '">' + escapeHtml(item.name) + ' <span class="count">(' + item.count + ')</span></label>' +
      '</div>';
    }).join('');
  }
  
  // ── FIELD SELECTORS ──
  function renderFieldSelectors() {
    const fields = [
      { key: 'sku', label: 'SKU', default: true },
      { key: 'title', label: 'Title', default: true },
      { key: 'productType', label: 'Product Type', default: true },
      { key: 'status', label: 'Status', default: true },
      { key: 'tags', label: 'Tags', default: true },
      { key: 'vendor', label: 'Vendor', default: true },
      { key: 'category', label: 'Category', default: true },
      { key: 'images', label: 'Images (first 3 URLs)', default: true },
      { key: 'metafields', label: 'Metafields', default: true },
      { key: 'variants', label: 'Variants', default: false },
      { key: 'descriptionHtml', label: 'Description (HTML)', default: false },
      { key: 'seo', label: 'SEO Title & Description', default: false },
    ];
    
    const container = document.getElementById('fieldSelectors');
    container.innerHTML = fields.map(f => {
      const checked = f.default ? 'checked' : '';
      return '<div class="check-item">' +
        '<input type="checkbox" id="field_' + f.key + '" name="field" value="' + f.key + '" ' + checked + '>' +
        '<label for="field_' + f.key + '">' + f.label + '</label>' +
      '</div>';
    }).join('');
  }
  
  // ── TOGGLE HELPERS ──
  function toggleSection(header) {
    header.classList.toggle('collapsed');
    header.nextElementSibling.classList.toggle('collapsed');
  }
  
  function toggleAll(namePrefix) {
    const checkboxes = document.querySelectorAll('input[name="' + namePrefix + '"]');
    const allChecked = Array.from(checkboxes).every(cb => cb.checked);
    checkboxes.forEach(cb => cb.checked = !allChecked);
  }
  
  // ── GET SELECTED VALUES ──
  function getSelected(namePrefix) {
    return Array.from(document.querySelectorAll('input[name="' + namePrefix + '"]:checked'))
      .map(cb => cb.value);
  }
  
  // ── PREVIEW ──
  function loadPreview() {
    const area = document.getElementById('previewArea');
    area.innerHTML = '<div class="preview-box"><div class="loading"><div class="spinner"></div></div></div>';
    
    const selectedTypes = getSelected('ptFilter');
    const type = selectedTypes.length === 1 ? selectedTypes[0] : '';
    
    google.script.run
      .withSuccessHandler(renderPreview)
      .withFailureHandler(e => { area.innerHTML = '<p style="color:red">❌ ' + e.message + '</p>'; })
      .fetchSampleProduct(type);
  }
  
  function renderPreview(product) {
    const area = document.getElementById('previewArea');
    if (!product) {
      area.innerHTML = '<div class="preview-box">No products found</div>';
      return;
    }
    
    let html = '<div class="preview-box">';
    html += '<div style="font-weight:600; margin-bottom:8px;">📦 ' + escapeHtml(product.title) + '</div>';
    html += field('Handle', product.handle);
    html += field('Type', product.productType);
    html += field('Status', product.status);
    html += field('Tags', product.tags);
    html += field('Vendor', product.vendor);
    html += field('Category', product.category);
    
    if (product.images.length > 0) {
      html += '<div class="field"><span class="field-label">Images:</span> ' + product.images.length + ' images</div>';
    }
    
    if (product.metafields.length > 0) {
      html += '<div style="margin-top:8px; font-weight:600;">Metafields:</div>';
      product.metafields.forEach(mf => {
        html += '<div class="field"><span class="field-label">' + escapeHtml(mf.key) + ':</span> <span class="field-value">' + escapeHtml(mf.value) + '</span></div>';
      });
    }
    
    html += '</div>';
    area.innerHTML = html;
  }
  
  function field(label, value) {
    return '<div class="field"><span class="field-label">' + label + ':</span> <span class="field-value">' + escapeHtml(value || '(empty)') + '</span></div>';
  }
  
  // ── EXECUTE PULL ──
  function executePull() {
    const btn = document.getElementById('pullBtn');
    const status = document.getElementById('statusText');
    btn.disabled = true;
    status.textContent = '🔄 Pulling products...';
    
    // Gather selections
    const options = {
      filters: {
        statuses: getSelected('statusFilter'),
        productTypes: getSelected('ptFilter'),
        vendors: getSelected('vendorFilter'),
        tags: getSelected('tagFilter')
      },
      fields: {},
      metafieldKeys: getSelected('mfKey')
    };
    
    // Fields
    const fieldCheckboxes = document.querySelectorAll('input[name="field"]:checked');
    fieldCheckboxes.forEach(cb => { options.fields[cb.value] = true; });
    
    google.script.run
      .withSuccessHandler(result => {
        btn.disabled = false;
        status.textContent = '✅ Pulled ' + result.count + ' products to Data tab';
      })
      .withFailureHandler(err => {
        btn.disabled = false;
        status.textContent = '❌ ' + err.message;
      })
      .executePull(options);
  }
  
  // ── UTILS ──
  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>

</body>
</html>`;
}
// ── MAIN FUNCTION: BUILD TAXONOMY REFERENCE ─────────────────
// This is the function that does all the work.
// It runs when you click "Build Taxonomy Reference" in the menu.
 
function buildTaxonomyReference() {
  const ui = SpreadsheetApp.getUi();
  
  try {
    ui.alert(
      '🏷️ Building Taxonomy Reference',
      'This will:\n\n' +
      '1. Scan your products to find which categories are in use\n' +
      '2. Fetch the available attributes for each category\n' +
      '3. Fetch your store\'s metaobject entries\n' +
      '4. Write everything to a "Taxonomy Reference" sheet\n\n' +
      'This may take 1-3 minutes. Click OK to start.',
      ui.ButtonSet.OK_CANCEL
    ) === ui.Button.CANCEL && (() => { return; })();
    
    const token = getAccessToken_();
    const config = getConfig_();
    const ss = SpreadsheetApp.getActiveSpreadsheet();
    
    // ── STEP 1: Find which categories your products use ─────
    Logger.log('Step 1: Scanning product categories...');
    const categoryMap = scanProductCategories_(token, config);
    
    if (Object.keys(categoryMap).length === 0) {
      ui.alert('⚠️ No categorized products found.\n\nMake sure your products have a Category assigned in Shopify.');
      return;
    }
    
    // ── STEP 2: For each category, get its taxonomy attributes ─
    Logger.log('Step 2: Fetching taxonomy attributes for each category...');
    const taxonomyData = fetchTaxonomyAttributes_(token, config, categoryMap);
    
    // ── STEP 3: Fetch metaobject definitions & entries ───────
    Logger.log('Step 3: Fetching metaobject entries from your store...');
    const metaobjectData = fetchStoreMetaobjects_(token, config, taxonomyData);
    
    // ── STEP 4: Write to the Taxonomy Reference sheet ────────
    Logger.log('Step 4: Writing to sheet...');
    writeTaxonomyReferenceSheet_(ss, categoryMap, taxonomyData, metaobjectData);
    
    // ── DONE ─────────────────────────────────────────────────
    const catCount = Object.keys(categoryMap).length;
    const attrCount = Object.values(taxonomyData).reduce((sum, attrs) => sum + attrs.length, 0);
    
    logAction_(ss, 'TAXONOMY REF', 
      `${catCount} categories, ${attrCount} attributes scanned`, '✅ Success');
    
    ui.alert(
      '✅ Taxonomy Reference Built!',
      `Found:\n` +
      `• ${catCount} product categories in use\n` +
      `• ${attrCount} total attributes across those categories\n\n` +
      `Check the "Taxonomy Reference" sheet.\n` +
      `It has two sections:\n` +
      `  📋 Top: Category → Attribute mapping\n` +
      `  📋 Below: Attribute → Allowed Values with GIDs`,
      ui.ButtonSet.OK
    );
    
  } catch (e) {
    ui.alert('❌ Failed to build taxonomy reference:\n\n' + e.message);
    Logger.log('Taxonomy reference error: ' + e.stack);
  }
}
 
 
// ── STEP 1 HELPER: Scan products to find categories in use ──
// Goes through all products and collects unique category IDs
// along with their names and how many products use each.
 
function scanProductCategories_(token, config) {
  const categoryMap = {};  // categoryId -> { name, fullName, productCount }
  let cursor = null;
  let hasNextPage = true;
  
  while (hasNextPage) {
    const afterClause = cursor ? `, after: "${cursor}"` : '';
    
    const query = `{
      products(first: 100${afterClause}) {
        edges {
          node {
            category {
              id
              name
              fullName
            }
          }
          cursor
        }
        pageInfo { hasNextPage }
      }
    }`;
    
    const result = shopifyGraphQL_(token, config.shopDomain, query);
    const edges = result.data.products.edges;
    hasNextPage = result.data.products.pageInfo.hasNextPage;
    
    if (edges.length > 0) {
      cursor = edges[edges.length - 1].cursor;
    } else {
      hasNextPage = false;
    }
    
    edges.forEach(edge => {
      const cat = edge.node.category;
      if (cat && cat.id) {
        if (!categoryMap[cat.id]) {
          categoryMap[cat.id] = {
            id: cat.id,
            name: cat.name,
            fullName: cat.fullName,
            productCount: 0
          };
        }
        categoryMap[cat.id].productCount++;
      }
    });
    
    Utilities.sleep(300);
  }
  
  Logger.log(`Found ${Object.keys(categoryMap).length} unique categories`);
  return categoryMap;
}
 
// ── FIXED STEP 2 HELPER (v4 — FINAL) ───────────────────────
// REPLACE your existing fetchTaxonomyAttributes_ function with this one.
//
// The issue: TaxonomyAttribute (generic) doesn't have a 'name' field,
// only TaxonomyChoiceListAttribute and TaxonomyMeasurementAttribute do.
// Removed the generic fragment — we only need choice list attributes anyway.

function fetchTaxonomyAttributes_(token, config, categoryMap) {
  var taxonomyData = {};
  var categoryIds = Object.keys(categoryMap);

  for (var i = 0; i < categoryIds.length; i++) {
    var catId = categoryIds[i];
    var cat = categoryMap[catId];

    Logger.log('  Fetching attributes for: ' + cat.name + ' (' + (i + 1) + '/' + categoryIds.length + ')');

    if (catId === 'gid://shopify/TaxonomyCategory/na') {
      taxonomyData[catId] = [];
      Logger.log('    Skipping uncategorized');
      continue;
    }

    var query = '{ node(id: "' + catId + '") { ... on TaxonomyCategory { id name fullName attributes(first: 50) { edges { node { ... on TaxonomyChoiceListAttribute { id name values(first: 250) { edges { node { id name } } } } ... on TaxonomyMeasurementAttribute { id name } } } } } } }';

    try {
      var result = shopifyGraphQL_(token, config.shopDomain, query);

      if (!result.data.node) {
        Logger.log('    node query returned null for ' + catId);
        taxonomyData[catId] = [];
        continue;
      }

      var catNode = result.data.node;
      var attributes = [];

      if (catNode.attributes && catNode.attributes.edges) {
        catNode.attributes.edges.forEach(function(attrEdge) {
          var attr = attrEdge.node;

          if (attr.values) {
            attributes.push({
              id: attr.id,
              name: attr.name,
              values: attr.values.edges.map(function(vEdge) {
                return { id: vEdge.node.id, name: vEdge.node.name };
              })
            });
          } else if (attr.name) {
            attributes.push({
              id: attr.id,
              name: attr.name,
              type: 'non-choice',
              values: []
            });
          }
        });
      }

      taxonomyData[catId] = attributes;
      Logger.log('    Found ' + attributes.length + ' attributes for ' + cat.name);

    } catch (e) {
      Logger.log('  Error fetching attributes for ' + cat.name + ': ' + e.message);
      taxonomyData[catId] = [];
    }

    Utilities.sleep(500);
  }

  return taxonomyData;
}
 
 
// ── STEP 3 HELPER: Fetch metaobject entries from your store ──
// Category metafields are stored as metaobject references.
// Each attribute (like "Fabric") has a corresponding metaobject type
// (like "shopify--fabric") in your store.
//
// This function:
// 1. Lists all metaobject definitions that start with "shopify--"
// 2. For each one, fetches all entries (the actual selectable values)
// 3. Maps each entry to its display name and GID
 
function fetchStoreMetaobjects_(token, config, taxonomyData) {
  const metaobjectData = {};  // type -> [{ gid, displayName, handle, fields }]
  
  // First, get all standard (shopify--*) metaobject definitions
  const defQuery = `{
    metaobjectDefinitions(first: 100) {
      edges {
        node {
          id
          name
          type
          fieldDefinitions {
            key
            name
            type { name }
          }
        }
      }
    }
  }`;
  
  const defResult = shopifyGraphQL_(token, config.shopDomain, defQuery);
  const allDefs = defResult.data.metaobjectDefinitions.edges.map(e => e.node);
  
  // Filter to only shopify-- standard definitions (category metafield types)
  const standardDefs = allDefs.filter(d => d.type.startsWith('shopify--'));
  
  Logger.log(`Found ${standardDefs.length} standard metaobject definitions: ${standardDefs.map(d => d.type).join(', ')}`);
  
  // For each standard definition, fetch its entries
  for (const def of standardDefs) {
    Logger.log(`  Fetching entries for: ${def.type} (${def.name})`);
    
    let entries = [];
    let cursor = null;
    let hasNextPage = true;
    
    while (hasNextPage) {
      const afterClause = cursor ? `, after: "${cursor}"` : '';
      
      const entryQuery = `{
        metaobjects(type: "${def.type}", first: 100${afterClause}) {
          edges {
            node {
              id
              handle
              displayName
              fields {
                key
                value
                type
              }
            }
            cursor
          }
          pageInfo { hasNextPage }
        }
      }`;
      
      try {
        const entryResult = shopifyGraphQL_(token, config.shopDomain, entryQuery);
        const edges = entryResult.data.metaobjects.edges;
        hasNextPage = entryResult.data.metaobjects.pageInfo.hasNextPage;
        
        if (edges.length > 0) {
          cursor = edges[edges.length - 1].cursor;
          edges.forEach(e => {
            entries.push({
              gid: e.node.id,
              handle: e.node.handle,
              displayName: e.node.displayName,
              fields: e.node.fields
            });
          });
        } else {
          hasNextPage = false;
        }
        
      } catch (e) {
        Logger.log(`  Error fetching entries for ${def.type}: ${e.message}`);
        hasNextPage = false;
      }
      
      Utilities.sleep(300);
    }
    
    metaobjectData[def.type] = {
      definitionId: def.id,
      name: def.name,
      type: def.type,
      fieldDefinitions: def.fieldDefinitions,
      entries: entries
    };
    
    Logger.log(`    Found ${entries.length} entries`);
  }
  
  return metaobjectData;
}
 
 
// ── STEP 4 HELPER: Write the Taxonomy Reference sheet ────────
// Creates (or overwrites) a sheet called "Taxonomy Reference" with:
//
// SECTION 1 — "Categories & Their Attributes"
//   Shows which attributes are available for each category.
//   Columns: Category ID | Category Name | Full Path | Products | Attribute | Attribute ID
//
// SECTION 2 — "Attribute Values (Your Store's Metaobject Entries)"
//   Shows the allowed values for each attribute, with your store's GIDs.
//   Columns: Metaobject Type | Attribute Name | Display Name | Metaobject GID | Handle
//
// This sheet is the "Rosetta Stone" — when you later pull category metafields,
// the script uses this sheet to convert GIDs to readable names and back.
 
function writeTaxonomyReferenceSheet_(ss, categoryMap, taxonomyData, metaobjectData) {
  let sheet = ss.getSheetByName('Taxonomy Reference');
  if (!sheet) {
    sheet = ss.insertSheet('Taxonomy Reference');
  }
  sheet.clear();
  
  let currentRow = 1;
  
  // ── SECTION 1 HEADER ──
  sheet.getRange(currentRow, 1).setValue('📋 SECTION 1: Categories & Their Attributes')
    .setFontWeight('bold').setFontSize(12);
  currentRow += 1;
  
  sheet.getRange(currentRow, 1).setValue('Shows which taxonomy attributes are available for each product category in your store.')
    .setFontColor('#888888').setFontSize(10);
  currentRow += 1;
  
  const sec1Headers = [
    'Category ID', 'Category Name', 'Full Path', 'Products',
    'Attribute Name', 'Attribute ID', 'Type', 'Value Count'
  ];
  sheet.getRange(currentRow, 1, 1, sec1Headers.length)
    .setValues([sec1Headers])
    .setFontWeight('bold')
    .setBackground('#d9e2f3');
  currentRow += 1;
  
  // ── SECTION 1 DATA ──
  const sec1StartRow = currentRow;
  
  // Sort categories by product count (most products first)
  const sortedCatIds = Object.keys(categoryMap).sort((a, b) => 
    categoryMap[b].productCount - categoryMap[a].productCount
  );
  
  for (const catId of sortedCatIds) {
    const cat = categoryMap[catId];
    const attrs = taxonomyData[catId] || [];
    
    if (attrs.length === 0) {
      // Category has no attributes — still show it
      sheet.getRange(currentRow, 1, 1, sec1Headers.length).setValues([[
        catId, cat.name, cat.fullName, cat.productCount,
        '(no attributes)', '', '', ''
      ]]);
      currentRow += 1;
    } else {
      for (const attr of attrs) {
        const attrType = attr.type === 'non-choice' ? 'Measurement/Other' : 'Choice List';
        sheet.getRange(currentRow, 1, 1, sec1Headers.length).setValues([[
          catId, cat.name, cat.fullName, cat.productCount,
          attr.name, attr.id, attrType, attr.values.length
        ]]);
        currentRow += 1;
      }
    }
  }
  
  // Add a gap before section 2
  currentRow += 2;
  
  // ── SECTION 2 HEADER ──
  sheet.getRange(currentRow, 1).setValue('📋 SECTION 2: Attribute Values (Metaobject Entries in Your Store)')
    .setFontWeight('bold').setFontSize(12);
  currentRow += 1;
  
  sheet.getRange(currentRow, 1).setValue('These are the actual values available in dropdowns. The Metaobject GID is what the API needs when pushing.')
    .setFontColor('#888888').setFontSize(10);
  currentRow += 1;
  
  const sec2Headers = [
    'Metaobject Type', 'Attribute Name', 'Display Name', 
    'Metaobject GID', 'Handle'
  ];
  sheet.getRange(currentRow, 1, 1, sec2Headers.length)
    .setValues([sec2Headers])
    .setFontWeight('bold')
    .setBackground('#e2f0d9');
  currentRow += 1;
  
  // ── SECTION 2 DATA ──
  // Sort metaobject types alphabetically
  const sortedTypes = Object.keys(metaobjectData).sort();
  
  for (const moType of sortedTypes) {
    const mo = metaobjectData[moType];
    
    if (mo.entries.length === 0) {
      sheet.getRange(currentRow, 1, 1, sec2Headers.length).setValues([[
        moType, mo.name, '(no entries)', '', ''
      ]]);
      currentRow += 1;
    } else {
      // Sort entries by display name
      const sortedEntries = mo.entries.sort((a, b) => 
        (a.displayName || '').localeCompare(b.displayName || '')
      );
      
      for (const entry of sortedEntries) {
        sheet.getRange(currentRow, 1, 1, sec2Headers.length).setValues([[
          moType, mo.name, entry.displayName, entry.gid, entry.handle
        ]]);
        currentRow += 1;
      }
    }
  }
  
  // ── FORMATTING ──
  // Auto-resize the important columns
  for (let i = 1; i <= Math.max(sec1Headers.length, sec2Headers.length); i++) {
    try { sheet.autoResizeColumn(i); } catch (e) { /* ignore */ }
  }
  
  // Freeze the first row area isn't useful here since we have two sections,
  // but we can at least add a timestamp
  currentRow += 2;
  sheet.getRange(currentRow, 1).setValue('Last refreshed:').setFontWeight('bold');
  sheet.getRange(currentRow, 2).setValue(new Date());
  
  // Set sheet tab color to distinguish it
  sheet.setTabColor('#9fc5e8');
}
