// ── LIST METAFIELD DEFINITIONS ──────────────────────────────

function listMetafieldDefinitions() {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  try {
    const token = getAccessToken_();
    const config = getConfig_();
    
    const query = `{
      metafieldDefinitions(first: 100, ownerType: PRODUCT) {
        edges {
          node { id name namespace key type { name } pinnedPosition }
        }
      }
    }`;
    
    const result = shopifyGraphQL_(token, config.shopDomain, query);
    const defs = result.data.metafieldDefinitions.edges.map(e => e.node);
    
    let defSheet = ss.getSheetByName('Metafield Definitions');
    if (!defSheet) defSheet = ss.insertSheet('Metafield Definitions');
    defSheet.clear();
    
    const headers = ['Definition ID', 'Name', 'Namespace', 'Key', 'Type', 'Pinned'];
    defSheet.getRange(1, 1, 1, headers.length).setValues([headers]).setFontWeight('bold');
    
    if (defs.length > 0) {
      const rows = defs.map(d => [d.id, d.name, d.namespace, d.key, d.type.name, d.pinnedPosition || '']);
      defSheet.getRange(2, 1, rows.length, headers.length).setValues(rows);
    }
    
    SpreadsheetApp.getUi().alert(`✅ Found ${defs.length} metafield definitions.`);
  } catch (e) {
    SpreadsheetApp.getUi().alert('❌ Failed:\n\n' + e.message);
  }
}

