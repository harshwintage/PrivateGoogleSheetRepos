function addPushDropdowns() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var pushSheet = ss.getSheetByName('Push');
  
  if (!pushSheet) {
    SpreadsheetApp.getUi().alert('No Push tab found. Copy rows from the Data tab first.');
    return;
  }
  
  var taxRef = loadTaxonomyReference_();
  if (!taxRef) {
    SpreadsheetApp.getUi().alert('No Taxonomy Reference sheet found. Run "Build Taxonomy Reference" first.');
    return;
  }
  
  var headers = pushSheet.getRange(1, 1, 1, pushSheet.getLastColumn()).getValues()[0];
  var lastRow = pushSheet.getLastRow();
  
  if (lastRow < 2) {
    SpreadsheetApp.getUi().alert('Push tab has no data rows. Copy some rows from the Data tab first.');
    return;
  }
  
  var dropdownCount = 0;
  
  for (var col = 0; col < headers.length; col++) {
    var header = headers[col] ? headers[col].toString().trim() : '';
    
    if (header.indexOf('CAT: ') !== 0) continue;
    
    var catInfo = catColumnToMetafieldKey_(header, taxRef);
    if (!catInfo) continue;
    
    var lookupTable = taxRef.displayNameToGid[catInfo.moType];
    if (!lookupTable) continue;
    
    var allowedValues = Object.keys(lookupTable).sort();
    if (allowedValues.length === 0) continue;
    
    var range = pushSheet.getRange(2, col + 1, lastRow - 1, 1);
    
    var rule = SpreadsheetApp.newDataValidation()
      .requireValueInList(allowedValues, true)
      .setAllowInvalid(false)
      .setHelpText('Pick from: ' + allowedValues.join(', '))
      .build();
    
    range.setDataValidation(rule);
    dropdownCount++;
  }
  
  if (dropdownCount > 0) {
    SpreadsheetApp.getUi().alert(
      '✅ Added dropdowns to ' + dropdownCount + ' CAT: column(s) in the Push tab.\n\n' +
      'Click any cell in a CAT: column to see the dropdown.'
    );
  } else {
    SpreadsheetApp.getUi().alert(
      'No CAT: columns found in the Push tab.\n' +
      'Make sure you pulled with metafields enabled and copied those columns to Push.'
    );
  }
}
