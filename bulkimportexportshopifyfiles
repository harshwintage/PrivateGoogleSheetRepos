// ── FETCH STORE METADATA (called from sidebar) ─────────────
// Gets all unique product types, tags, vendors, statuses, and metafield keys

function fetchStoreMetadata() {
  const token = getAccessToken_();
  const config = getConfig_();
  
  // We'll scan products to build frequency maps
  const productTypes = {};
  const tags = {};
  const vendors = {};
  const statuses = { 'ACTIVE': 0, 'DRAFT': 0, 'ARCHIVED': 0 };
  const metafieldKeys = {};
  
  let cursor = null;
  let hasNextPage = true;
  let totalProducts = 0;
  
  while (hasNextPage) {
    const afterClause = cursor ? `, after: "${cursor}"` : '';
    const query = `{
      products(first: 100${afterClause}) {
        edges {
          node {
            productType
            tags
            vendor
            status
            metafields(first: 50) {
              edges {
                node {
                  namespace
                  key
                }
              }
            }
          }
          cursor
        }
        pageInfo { hasNextPage }
      }
    }`;
    
    const result = shopifyGraphQL_(token, config.shopDomain, query);
    const edges = result.data.products.edges;
    hasNextPage = result.data.products.pageInfo.hasNextPage;
    
    if (edges.length > 0) {
      cursor = edges[edges.length - 1].cursor;
    } else {
      hasNextPage = false;
    }
    
    edges.forEach(edge => {
      const p = edge.node;
      totalProducts++;
      
      // Product type frequency
      if (p.productType) {
        productTypes[p.productType] = (productTypes[p.productType] || 0) + 1;
      }
      
      // Tags frequency
      if (p.tags) {
        p.tags.forEach(tag => {
          tags[tag] = (tags[tag] || 0) + 1;
        });
      }
      
      // Vendor frequency
      if (p.vendor) {
        vendors[p.vendor] = (vendors[p.vendor] || 0) + 1;
      }
      
      // Status count
      if (p.status) {
        statuses[p.status] = (statuses[p.status] || 0) + 1;
      }
      
      // Metafield keys
      if (p.metafields?.edges) {
        p.metafields.edges.forEach(mf => {
          const key = `${mf.node.namespace}.${mf.node.key}`;
          metafieldKeys[key] = (metafieldKeys[key] || 0) + 1;
        });
      }
    });
    
    Utilities.sleep(300);
  }
  
  // Sort by frequency (most common first)
  const sortByFreq = (obj) => Object.entries(obj)
    .sort((a, b) => b[1] - a[1])
    .map(([name, count]) => ({ name, count }));
  
  return {
    totalProducts,
    productTypes: sortByFreq(productTypes),
    tags: sortByFreq(tags),
    vendors: sortByFreq(vendors),
    statuses: sortByFreq(statuses),
    metafieldKeys: sortByFreq(metafieldKeys)
  };
}

// ── FETCH SAMPLE PRODUCT (called from sidebar) ──────────────

function fetchSampleProduct(productType) {
  const token = getAccessToken_();
  const config = getConfig_();
  
  const queryFilter = productType ? `, query: "product_type:'${productType}'"` : '';
  
  const query = `{
    products(first: 1${queryFilter}) {
      edges {
        node {
          handle
          title
          productType
          status
          tags
          vendor
          category { fullName }
          images(first: 3) { edges { node { url } } }
          metafields(first: 20) {
            edges {
              node {
                namespace
                key
                value
                type
              }
            }
          }
        }
      }
    }
  }`;
  
  const result = shopifyGraphQL_(token, config.shopDomain, query);
  const product = result.data.products.edges[0]?.node;
  
  if (!product) return null;
  
  return {
    handle: product.handle,
    title: product.title,
    productType: product.productType,
    status: product.status,
    tags: product.tags?.join(', '),
    vendor: product.vendor,
    category: product.category?.fullName || '(none)',
    images: product.images?.edges?.map(e => e.node.url) || [],
    metafields: product.metafields?.edges?.map(e => ({
      key: `${e.node.namespace}.${e.node.key}`,
      value: e.node.value,
      type: e.node.type
    })) || []
  };
}

// ── EXECUTE PULL (called from sidebar) ──────────────────────

function executePull(options) {
  // options = { filters: { productTypes: [], tags: [], vendors: [], statuses: [] },
  //             fields: { title: true, handle: true, ... },
  //             metafieldKeys: [] }
  
  const token = getAccessToken_();
  const config = getConfig_();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  
  // Build GraphQL query filter string
  const queryParts = [];
  
  if (options.filters.statuses && options.filters.statuses.length > 0) {
    if (options.filters.statuses.length === 1) {
      queryParts.push(`status:${options.filters.statuses[0]}`);
    } else {
      const statusOr = options.filters.statuses.map(s => `status:${s}`).join(' OR ');
      queryParts.push(`(${statusOr})`);
    }
  }
  
  if (options.filters.productTypes && options.filters.productTypes.length > 0) {
    if (options.filters.productTypes.length === 1) {
      queryParts.push(`product_type:'${options.filters.productTypes[0]}'`);
    } else {
      const ptOr = options.filters.productTypes.map(pt => `product_type:'${pt}'`).join(' OR ');
      queryParts.push(`(${ptOr})`);
    }
  }
  
  if (options.filters.vendors && options.filters.vendors.length > 0) {
    if (options.filters.vendors.length === 1) {
      queryParts.push(`vendor:'${options.filters.vendors[0]}'`);
    } else {
      const vOr = options.filters.vendors.map(v => `vendor:'${v}'`).join(' OR ');
      queryParts.push(`(${vOr})`);
    }
  }
  
  if (options.filters.tags && options.filters.tags.length > 0) {
    options.filters.tags.forEach(tag => {
      queryParts.push(`tag:'${tag}'`);
    });
  }
  
  const queryFilter = queryParts.join(' AND ');
  
  // Build GraphQL product fields
  let productFields = '\n    id\n    handle';
  const f = options.fields;
  
  if (f.title) productFields += '\n    title';
  if (f.productType) productFields += '\n    productType';
  if (f.status) productFields += '\n    status';
  if (f.tags) productFields += '\n    tags';
  if (f.vendor) productFields += '\n    vendor';
  if (f.category) productFields += '\n    category { id name fullName }';
  if (f.descriptionHtml) productFields += '\n    descriptionHtml';
  if (f.seo) productFields += '\n    seo { title description }';
  if (f.images) productFields += '\n    images(first: 10) { edges { node { url altText } } }';
  // Variants / SKU — handle both fields needing variant data
  const needsVariants = f.sku || f.variants;
  if (needsVariants) {
    if (f.variants) {
      productFields += '\n    variants(first: 100) { edges { node { id title sku price inventoryQuantity } } }';
    } else {
      // Only need SKU
      productFields += '\n    variants(first: 100) { edges { node { sku } } }';
    }
  }
  if (f.metafields) productFields += '\n    metafields(first: 50) { edges { node { namespace key value type } } }';
  
  // Paginate through products
  let allProducts = [];
  let cursor = null;
  let hasNextPage = true;
  
  while (hasNextPage) {
    const afterClause = cursor ? `, after: "${cursor}"` : '';
    const filterClause = queryFilter ? `, query: "${queryFilter.replace(/"/g, '\\"')}"` : '';
    
    const query = `{
      products(first: 50${afterClause}${filterClause}, sortKey: TITLE) {
        edges {
          node { ${productFields} }
          cursor
        }
        pageInfo { hasNextPage }
      }
    }`;
    
    const result = shopifyGraphQL_(token, config.shopDomain, query);
    const edges = result.data.products.edges;
    hasNextPage = result.data.products.pageInfo.hasNextPage;
    
    if (edges.length > 0) {
      cursor = edges[edges.length - 1].cursor;
      edges.forEach(edge => allProducts.push(edge.node));
    } else {
      hasNextPage = false;
    }
    
    Utilities.sleep(500);
  }
  
  // Filter metafields by selected keys
  if (f.metafields && options.metafieldKeys && options.metafieldKeys.length > 0) {
    allProducts = allProducts.map(product => {
      if (product.metafields?.edges) {
        product.metafields.edges = product.metafields.edges.filter(edge => {
          const key = `${edge.node.namespace}.${edge.node.key}`;
          return options.metafieldKeys.includes(key);
        });
      }
      return product;
    });
  }
  
  // Write to Data sheet
  writeToDataSheet_(ss, allProducts, f, options.metafieldKeys);
  
  // Log
  logAction_(ss, 'PULL', `${allProducts.length} products. Filter: ${queryFilter || 'none'}`, '✅ Success');
  
  return { count: allProducts.length };
}

// ── WRITE DATA TO SHEET ─────────────────────────────────────

function writeToDataSheet_(ss, products, fields, selectedMetafieldKeys) {
  let dataSheet = ss.getSheetByName('Data');
  if (!dataSheet) dataSheet = ss.insertSheet('Data');
  
  // Remove existing protection so we can write
  dataSheet.getProtections(SpreadsheetApp.ProtectionType.SHEET).forEach(p => {
    if (p.canEdit()) p.remove();
  });
  
  dataSheet.clear();
  
  if (products.length === 0) {
    dataSheet.getRange('A1').setValue('No products found matching your filters');
    return;
  }
  
  // Build headers
  const headers = ['Product ID', 'Handle'];
  if (fields.sku) headers.push('SKU');
  if (fields.title) headers.push('Title');
  if (fields.productType) headers.push('Product Type');
  if (fields.status) headers.push('Status');
  if (fields.tags) headers.push('Tags');
  if (fields.category) headers.push('Category ID', 'Category Name', 'Category Full Name');
  if (fields.vendor) headers.push('Vendor');
  if (fields.descriptionHtml) headers.push('Description (HTML)');
  if (fields.seo) headers.push('SEO Title', 'SEO Description');
  if (fields.images) headers.push('Image 1', 'Image 2', 'Image 3');
  
  // Metafield columns
  let metafieldKeys = [];
  if (fields.metafields) {
    if (selectedMetafieldKeys && selectedMetafieldKeys.length > 0) {
      metafieldKeys = selectedMetafieldKeys;
    } else {
      // Discover all keys from data
      const keySet = new Set();
      products.forEach(p => {
        if (p.metafields?.edges) {
          p.metafields.edges.forEach(e => keySet.add(`${e.node.namespace}.${e.node.key}`));
        }
      });
      metafieldKeys = Array.from(keySet).sort();
    }
    metafieldKeys.forEach(key => headers.push(`MF: ${key}`));
  }
  
  if (fields.variants) headers.push('Variant Count', 'Variants (JSON)');
  
  // Build rows
  const rows = products.map(product => {
    const row = [product.id, product.handle];
    
    if (fields.sku) {
      const skus = product.variants?.edges?.map(v => v.node.sku).filter(s => s) || [];
      row.push(skus.join(', '));
    }
    if (fields.title) row.push(product.title || '');
    if (fields.productType) row.push(product.productType || '');
    if (fields.status) row.push(product.status || '');
    if (fields.tags) row.push((product.tags || []).join(', '));
    if (fields.category) {
      row.push(product.category?.id || '', product.category?.name || '', product.category?.fullName || '');
    }
    if (fields.vendor) row.push(product.vendor || '');
    if (fields.descriptionHtml) row.push(product.descriptionHtml || '');
    if (fields.seo) {
      row.push(product.seo?.title || '', product.seo?.description || '');
    }
    if (fields.images) {
      const imgs = product.images?.edges || [];
      row.push(imgs[0]?.node?.url || '', imgs[1]?.node?.url || '', imgs[2]?.node?.url || '');
    }
    if (fields.metafields) {
      const mfMap = {};
      if (product.metafields?.edges) {
        product.metafields.edges.forEach(e => {
          mfMap[`${e.node.namespace}.${e.node.key}`] = e.node.value;
        });
      }
      metafieldKeys.forEach(key => row.push(mfMap[key] || ''));
    }
    if (fields.variants) {
      const vars = product.variants?.edges || [];
      row.push(vars.length, JSON.stringify(vars.map(v => v.node)));
    }
    
    return row;
  });
  
  // Write
  dataSheet.getRange(1, 1, 1, headers.length).setValues([headers]).setFontWeight('bold').setBackground('#e8e8e8');
  if (rows.length > 0) {
    dataSheet.getRange(2, 1, rows.length, headers.length).setValues(rows);
  }
  
  // Add pull timestamp
  dataSheet.getRange(1, headers.length + 2).setValue('Pulled at:').setFontWeight('bold');
  dataSheet.getRange(1, headers.length + 3).setValue(new Date());
  
  // Auto-resize columns (first 10)
  for (let i = 1; i <= Math.min(headers.length, 10); i++) {
    dataSheet.autoResizeColumn(i);
  }
  dataSheet.setFrozenRows(1);
  
  // PROTECT the sheet — read only for everyone except owner
  const protection = dataSheet.protect().setDescription('Auto-locked after pull. Do not edit — use Push tab.');
  // Remove all editors except the owner
  const me = Session.getEffectiveUser();
  protection.addEditor(me);
  try {
    protection.removeEditors(protection.getEditors());
    protection.addEditor(me);
  } catch (e) {
    // If we can't manage editors, at least set a warning
    protection.setWarningOnly(true);
  }
}

// ── LOGGING ─────────────────────────────────────────────────

function logAction_(ss, action, details, status) {
  let logsSheet = ss.getSheetByName('Logs');
  if (!logsSheet) {
    logsSheet = ss.insertSheet('Logs');
    logsSheet.getRange('A1:D1').setValues([['Timestamp', 'Action', 'Details', 'Status']]).setFontWeight('bold');
  }
  const nextRow = logsSheet.getLastRow() + 1;
  logsSheet.getRange(nextRow, 1, 1, 4).setValues([[new Date(), action, details, status]]);
}

