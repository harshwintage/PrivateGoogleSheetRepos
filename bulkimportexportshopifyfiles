function loadTaxonomyReference_() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sheet = ss.getSheetByName('Taxonomy Reference');
  
  if (!sheet) return null;
  
  var data = sheet.getDataRange().getValues();
  
  var gidToDisplayName = {};
  var displayNameToGid = {};
  var metaobjectTypeToAttributeName = {};
  var categoryAttributes = {};
  
  var inSection1 = false;
  var inSection2 = false;
  
  for (var i = 0; i < data.length; i++) {
    var row = data[i];
    
    if (row[0] && row[0].toString().indexOf('SECTION 1') !== -1) {
      inSection1 = true;
      inSection2 = false;
      continue;
    }
    if (row[0] && row[0].toString().indexOf('SECTION 2') !== -1) {
      inSection1 = false;
      inSection2 = true;
      continue;
    }
    
    if (row[0] === 'Category ID' || row[0] === 'Metaobject Type') continue;
    if (row[0] && row[0].toString().indexOf('Shows which') !== -1) continue;
    if (row[0] && row[0].toString().indexOf('These are the') !== -1) continue;
    
    if (inSection1) {
      var catId = row[0] ? row[0].toString().trim() : '';
      var attrName = row[4] ? row[4].toString().trim() : '';
      
      if (catId && attrName && attrName !== '(no attributes)') {
        if (!categoryAttributes[catId]) categoryAttributes[catId] = [];
        categoryAttributes[catId].push(attrName);
      }
    }
    
    if (inSection2) {
      var moType = row[0] ? row[0].toString().trim() : '';
      var attrDisplayName = row[1] ? row[1].toString().trim() : '';
      var valueName = row[2] ? row[2].toString().trim() : '';
      var gid = row[3] ? row[3].toString().trim() : '';
      var handle = row[4] ? row[4].toString().trim() : '';
      
      if (gid && valueName) {
        gidToDisplayName[gid] = valueName;
        
        if (moType && attrDisplayName) {
          metaobjectTypeToAttributeName[moType] = attrDisplayName;
        }
        
        if (moType) {
          if (!displayNameToGid[moType]) displayNameToGid[moType] = {};
          if (!displayNameToGid[moType][valueName]) {
            displayNameToGid[moType][valueName] = gid;
          }
        }
      }
    }
  }
  
  return {
    gidToDisplayName: gidToDisplayName,
    displayNameToGid: displayNameToGid,
    metaobjectTypeToAttributeName: metaobjectTypeToAttributeName,
    categoryAttributes: categoryAttributes
  };
}

function isCategoryMetafield_(namespaceKey) {
  return namespaceKey.indexOf('shopify.') === 0;
}

function resolveMetaobjectGids_(rawValue, gidToDisplayName) {
  if (!rawValue) return '';
  
  var value = rawValue.toString().trim();
  
  try {
    var gids = JSON.parse(value);
    if (Array.isArray(gids)) {
      var names = [];
      for (var i = 0; i < gids.length; i++) {
        var gid = gids[i].toString().trim();
        var name = gidToDisplayName[gid];
        if (name) {
          names.push(name);
        } else {
          names.push(gid);
        }
      }
      return names.join(', ');
    }
  } catch (e) {
    // Not valid JSON
  }
  
  if (value.indexOf('gid://shopify/Metaobject/') === 0) {
    return gidToDisplayName[value] || value;
  }
  
  return value;
}

function categoryMetafieldColumnName_(namespaceKey, taxRef) {
  var key = namespaceKey.replace('shopify.', '');
  var moType = 'shopify--' + key;
  
  if (taxRef && taxRef.metaobjectTypeToAttributeName[moType]) {
    return 'CAT: ' + taxRef.metaobjectTypeToAttributeName[moType];
  }
  
  var friendly = key.replace(/-/g, ' ').replace(/\b\w/g, function(c) { return c.toUpperCase(); });
  return 'CAT: ' + friendly;
}

function catColumnToMetafieldKey_(columnName, taxRef) {
  if (!columnName || columnName.indexOf('CAT: ') !== 0) return null;
  
  var attrName = columnName.replace('CAT: ', '');
  
  if (!taxRef) return null;
  
  var types = Object.keys(taxRef.metaobjectTypeToAttributeName);
  for (var i = 0; i < types.length; i++) {
    if (taxRef.metaobjectTypeToAttributeName[types[i]] === attrName) {
      var moType = types[i];
      var parts = moType.split('--');
      if (parts.length === 2) {
        return { namespace: parts[0], key: parts[1], moType: moType };
      }
    }
  }
  
  var guessedKey = attrName.toLowerCase().replace(/ /g, '-');
  return { namespace: 'shopify', key: guessedKey, moType: 'shopify--' + guessedKey };
}

function displayNamesToGidJson_(displayNamesCsv, moType, taxRef) {
  if (!displayNamesCsv || !displayNamesCsv.toString().trim()) return '[]';
  if (!taxRef) return '[]';
  
  var names = displayNamesCsv.toString().split(',').map(function(n) { return n.trim(); }).filter(function(n) { return n; });
  var gids = [];
  var errors = [];
  
  var lookupTable = taxRef.displayNameToGid[moType] || {};
  
  for (var i = 0; i < names.length; i++) {
    var name = names[i];
    var gid = lookupTable[name];
    
    if (gid) {
      gids.push(gid);
    } else {
      var found = false;
      var keys = Object.keys(lookupTable);
      for (var j = 0; j < keys.length; j++) {
        if (keys[j].toLowerCase() === name.toLowerCase()) {
          gids.push(lookupTable[keys[j]]);
          found = true;
          break;
        }
      }
      if (!found) {
        if (name.indexOf('gid://shopify/Metaobject/') === 0) {
          gids.push(name);
        } else {
          errors.push(name);
        }
      }
    }
  }
  
  if (errors.length > 0) {
    throw new Error('Unknown values for ' + moType + ': ' + errors.join(', ') + 
      '. Check the Taxonomy Reference sheet for valid values.');
  }
  
  return JSON.stringify(gids);
}

