// ── ANALYZE PUSH TAB (called from push sidebar) ─────────────

function analyzePushChanges() {
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var pushSheet = ss.getSheetByName('Push');
  var dataSheet = ss.getSheetByName('Data');
  
  if (!pushSheet) throw new Error('Push tab not found. Copy rows from Data tab into a sheet named "Push".');
  if (!dataSheet) throw new Error('Data tab not found. Run a Pull first.');
  
  var pushData = pushSheet.getDataRange().getValues();
  var dataData = dataSheet.getDataRange().getValues();
  
  if (pushData.length < 2) throw new Error('Push tab is empty (no data rows).');
  if (dataData.length < 2) throw new Error('Data tab is empty. Run a Pull first.');
  
  var pushHeaders = pushData[0].map(function(h) { return h.toString().trim(); });
  var dataHeaders = dataData[0].map(function(h) { return h.toString().trim(); });
  
  var pushIdCol = pushHeaders.indexOf('Product ID');
  if (pushIdCol === -1) throw new Error('Push tab must have a "Product ID" column.');
  
  var dataIdCol = dataHeaders.indexOf('Product ID');
  if (dataIdCol === -1) throw new Error('Data tab is missing "Product ID" column.');
  
  var dataLookup = {};
  for (var i = 1; i < dataData.length; i++) {
    var id = dataData[i][dataIdCol].toString().trim();
    if (id) {
      var rowObj = {};
      dataHeaders.forEach(function(h, col) { rowObj[h] = dataData[i][col]; });
      dataLookup[id] = rowObj;
    }
  }
  
  // Pushable fields — includes Price
  var pushableFields = ['Title', 'Tags', 'Category ID', 'Vendor', 'Product Type', 
    'Status', 'SEO Title', 'SEO Description', 'Description (HTML)', 'Price'];
  
  var mfColumns = pushHeaders.filter(function(h) { return h.indexOf('MF: ') === 0; });
  var catColumns = pushHeaders.filter(function(h) { return h.indexOf('CAT: ') === 0; });
  
  var allPushable = pushableFields.concat(mfColumns).concat(catColumns);
  
  // Read-only — includes Variant ID
  var readOnlyFields = ['Product ID', 'Handle', 'SKU', 'Variant ID', 'Category Name', 
    'Category Full Name', 'Image 1', 'Image 2', 'Image 3', 'Variant Count', 'Variants (JSON)'];
  
  var changes = [];
  
  for (var i = 1; i < pushData.length; i++) {
    var productId = pushData[i][pushIdCol].toString().trim();
    if (!productId) continue;
    
    var handle = pushData[i][pushHeaders.indexOf('Handle')] || '';
    var title = pushData[i][pushHeaders.indexOf('Title')] || '';
    
    // Grab Variant ID for price pushes
    var variantIdCol = pushHeaders.indexOf('Variant ID');
    var variantId = variantIdCol !== -1 ? (pushData[i][variantIdCol] || '').toString().trim() : '';
    
    var dataRow = dataLookup[productId];
    
    var rowChanges = [];
    
    allPushable.forEach(function(field) {
      var pushCol = pushHeaders.indexOf(field);
      if (pushCol === -1) return;
      
      var pushVal = pushData[i][pushCol] != null ? pushData[i][pushCol].toString().trim() : '';
      var dataVal = dataRow ? (dataRow[field] != null ? dataRow[field].toString().trim() : '') : '';
      
      if (pushVal !== dataVal) {
        rowChanges.push({
          field: field,
          oldValue: dataVal,
          newValue: pushVal
        });
      }
    });
    
    if (rowChanges.length > 0) {
      changes.push({
        productId: productId,
        variantId: variantId,
        handle: handle.toString(),
        title: title.toString(),
        rowNum: i + 1,
        changes: rowChanges
      });
    }
  }
  
  var pullTimestamp = dataSheet.getRange(1, dataHeaders.length + 3).getValue();
  
  return {
    totalPushRows: pushData.length - 1,
    productsWithChanges: changes.length,
    totalChanges: changes.reduce(function(sum, c) { return sum + c.changes.length; }, 0),
    pullTimestamp: pullTimestamp ? pullTimestamp.toString() : 'Unknown',
    changes: changes,
    pushableColumns: allPushable.filter(function(f) { return pushHeaders.indexOf(f) !== -1; }),
    readOnlyColumns: readOnlyFields.filter(function(f) { return pushHeaders.indexOf(f) !== -1; }),
    ignoredEdits: []
  };
}

// ── EXECUTE PUSH (CHUNKED) ──────────────────────────────────

var PUSH_BATCH_SIZE = 200;

function executePush(isDryRun) {
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const analysis = analyzePushChanges();
  
  if (analysis.productsWithChanges === 0) {
    return { success: true, message: 'No changes detected.', results: [] };
  }
  
  if (isDryRun) {
    return { success: true, message: 'Dry run complete.', dryRun: true, analysis: analysis };
  }
  
  const props = PropertiesService.getScriptProperties();
  props.setProperty('PUSH_CHANGES', JSON.stringify(analysis.changes));
  props.setProperty('PUSH_INDEX', '0');
  props.setProperty('PUSH_RESULTS', JSON.stringify([]));
  props.setProperty('PUSH_TOTAL', analysis.changes.length.toString());
  props.setProperty('PUSH_RUNNING', 'true');
  
  const batchResult = executePushBatch_();
  
  return batchResult;
}

function executePushBatch_() {
  var props = PropertiesService.getScriptProperties();
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  
  var changes = JSON.parse(props.getProperty('PUSH_CHANGES') || '[]');
  var startIndex = parseInt(props.getProperty('PUSH_INDEX') || '0');
  var results = JSON.parse(props.getProperty('PUSH_RESULTS') || '[]');
  var total = parseInt(props.getProperty('PUSH_TOTAL') || '0');
  
  if (changes.length === 0 || startIndex >= changes.length) {
    finalizePush_();
    return { success: true, message: 'No more products to push.', results: results };
  }
  
  var token = getAccessToken_();
  var config = getConfig_();
  
  var endIndex = Math.min(startIndex + PUSH_BATCH_SIZE, changes.length);
  Logger.log('📤 Push batch: products ' + (startIndex + 1) + ' to ' + endIndex + ' of ' + changes.length);
  
  for (var i = startIndex; i < endIndex; i++) {
    var product = changes[i];
    try {
      // Separate price changes from other changes
      var priceChange = null;
      var otherChanges = [];
      
      product.changes.forEach(function(change) {
        if (change.field === 'Price') {
          priceChange = change;
        } else {
          otherChanges.push(change);
        }
      });
      
      var updateDetails = [];
      
      // Push non-price changes via productUpdate
      if (otherChanges.length > 0) {
        var productWithOtherChanges = {
          productId: product.productId,
          handle: product.handle,
          changes: otherChanges
        };
        
        var mutation = buildUpdateMutation_(productWithOtherChanges);
        var result = shopifyGraphQL_(token, config.shopDomain, mutation.query, mutation.variables);
        
        var userErrors = result.data && result.data.productUpdate ? result.data.productUpdate.userErrors || [] : [];
        
        if (userErrors.length > 0) {
          results.push({
            productId: product.productId,
            handle: product.handle,
            status: '❌ Error',
            details: userErrors.map(function(e) { return e.field + ': ' + e.message; }).join('; ')
          });
          Utilities.sleep(500);
          continue;
        }
        
        updateDetails = otherChanges.map(function(c) { return c.field; });
      }
      
      // Push price change via productVariantsBulkUpdate
      if (priceChange && product.variantId) {
        var priceResult = pushVariantPrice_(token, config, product.productId, product.variantId, priceChange.newValue);
        
        if (priceResult.success) {
          updateDetails.push('Price');
        } else {
          results.push({
            productId: product.productId,
            handle: product.handle,
            status: '❌ Price Error',
            details: priceResult.error
          });
          Utilities.sleep(500);
          continue;
        }
      } else if (priceChange && !product.variantId) {
        results.push({
          productId: product.productId,
          handle: product.handle,
          status: '❌ Price Error',
          details: 'No Variant ID found. Make sure "Variant ID" column is in the Push tab.'
        });
        Utilities.sleep(500);
        continue;
      }
      
      results.push({
        productId: product.productId,
        handle: product.handle,
        status: '✅ Updated',
        details: updateDetails.join(', ')
      });
      
      Utilities.sleep(500);
      
    } catch (e) {
      results.push({
        productId: product.productId,
        handle: product.handle,
        status: '❌ Failed',
        details: e.message
      });
    }
  }
  
  // Save progress
  props.setProperty('PUSH_INDEX', endIndex.toString());
  props.setProperty('PUSH_RESULTS', JSON.stringify(results));
  
  if (endIndex < changes.length) {
    Logger.log('⏳ ' + (changes.length - endIndex) + ' products remaining. Scheduling next batch...');
    
    cleanPushTriggers_();
    
    ScriptApp.newTrigger('continuePush')
      .timeBased()
      .after(10 * 1000)
      .create();
    
    writePushResults_(ss, results);
    logAction_(ss, 'PUSH (batch)', endIndex + ' of ' + changes.length + ' processed so far', '🔄 In progress');
    
    return { 
      success: true, 
      message: 'Batch complete: ' + endIndex + ' of ' + changes.length + ' products processed. Next batch auto-scheduled.',
      results: results,
      inProgress: true,
      processed: endIndex,
      total: changes.length
    };
  } else {
    finalizePush_();
    return {
      success: true,
      message: 'Push complete. ' + results.filter(function(r) { return r.status.indexOf('✅') !== -1; }).length + ' updated, ' + results.filter(function(r) { return r.status.indexOf('❌') !== -1; }).length + ' failed.',
      results: results,
      inProgress: false
    };
  }
}

function continuePush() {
  cleanPushTriggers_();
  
  const props = PropertiesService.getScriptProperties();
  if (props.getProperty('PUSH_RUNNING') !== 'true') return;
  
  executePushBatch_();
}

function finalizePush_() {
  const props = PropertiesService.getScriptProperties();
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  const results = JSON.parse(props.getProperty('PUSH_RESULTS') || '[]');
  
  const successCount = results.filter(r => r.status.includes('✅')).length;
  const failCount = results.filter(r => r.status.includes('❌')).length;
  
  logAction_(ss, 'PUSH (complete)', `${successCount} succeeded, ${failCount} failed out of ${results.length} products`, 
    failCount === 0 ? '✅ Success' : '⚠️ Partial');
  
  writePushResults_(ss, results);
  
  props.deleteProperty('PUSH_CHANGES');
  props.deleteProperty('PUSH_INDEX');
  props.deleteProperty('PUSH_RESULTS');
  props.deleteProperty('PUSH_TOTAL');
  props.setProperty('PUSH_RUNNING', 'false');
  
  cleanPushTriggers_();
  
  Logger.log(`✅ Push finalized. ${successCount} updated, ${failCount} failed.`);
}

function cleanPushTriggers_() {
  ScriptApp.getProjectTriggers().forEach(trigger => {
    if (trigger.getHandlerFunction() === 'continuePush') {
      ScriptApp.deleteTrigger(trigger);
    }
  });
}

function getPushStatus() {
  const props = PropertiesService.getScriptProperties();
  const running = props.getProperty('PUSH_RUNNING') === 'true';
  const index = parseInt(props.getProperty('PUSH_INDEX') || '0');
  const total = parseInt(props.getProperty('PUSH_TOTAL') || '0');
  const results = JSON.parse(props.getProperty('PUSH_RESULTS') || '[]');
  
  return { running, processed: index, total, results };
}

function cancelPush() {
  finalizePush_();
  return { success: true, message: 'Push cancelled.' };
}

// ── BUILD UPDATE MUTATION ───────────────────────────────────

function buildUpdateMutation_(product) {
  var taxRef = loadTaxonomyReference_();
  
  var productInput = {
    id: product.productId
  };
  
  var metafields = [];
  
  product.changes.forEach(function(change) {
    if (change.field === 'Title') {
      productInput.title = change.newValue;
    }
    else if (change.field === 'Tags') {
      productInput.tags = change.newValue.split(',').map(function(t) { return t.trim(); }).filter(function(t) { return t; });
    }
    else if (change.field === 'Category ID') {
      productInput.category = change.newValue;
    }
    else if (change.field === 'Vendor') {
      productInput.vendor = change.newValue;
    }
    else if (change.field === 'Product Type') {
      productInput.productType = change.newValue;
    }
    else if (change.field === 'Status') {
      productInput.status = change.newValue.toUpperCase();
    }
    else if (change.field === 'Description (HTML)') {
      productInput.descriptionHtml = change.newValue;
    }
    else if (change.field === 'SEO Title') {
      if (!productInput.seo) productInput.seo = {};
      productInput.seo.title = change.newValue;
    }
    else if (change.field === 'SEO Description') {
      if (!productInput.seo) productInput.seo = {};
      productInput.seo.description = change.newValue;
    }
    // CAT: columns (category metafields)
    else if (change.field.indexOf('CAT: ') === 0) {
      var catInfo = catColumnToMetafieldKey_(change.field, taxRef);
      
      if (catInfo) {
        var gidJson = displayNamesToGidJson_(change.newValue, catInfo.moType, taxRef);
        
        metafields.push({
          namespace: catInfo.namespace,
          key: catInfo.key,
          value: gidJson,
          type: 'list.metaobject_reference'
        });
      }
    }
    // MF: columns (regular metafields)
    else if (change.field.indexOf('MF: ') === 0) {
      var fullKey = change.field.replace('MF: ', '');
      var dotIndex = fullKey.indexOf('.');
      var namespace = fullKey.substring(0, dotIndex);
      var key = fullKey.substring(dotIndex + 1);
      
      var mfType = 'single_line_text_field';
      var mfValue = change.newValue;
      
      if (mfValue.indexOf('gid://shopify/Metaobject/') === 0) {
        mfType = 'metaobject_reference';
      } else if (mfValue.indexOf('["gid://shopify/Metaobject/') === 0) {
        mfType = 'list.metaobject_reference';
      }
      
      metafields.push({
        namespace: namespace,
        key: key,
        value: mfValue,
        type: mfType
      });
    }
  });
  
  if (metafields.length > 0) {
    productInput.metafields = metafields;
  }
  
  var query = '\
    mutation UpdateProduct($product: ProductInput!) {\
      productUpdate(input: $product) {\
        product {\
          id\
          title\
          tags\
        }\
        userErrors {\
          field\
          message\
        }\
      }\
    }\
  ';
  
  return { query: query, variables: { product: productInput } };
}

// ── WRITE PUSH RESULTS ──────────────────────────────────────

function writePushResults_(ss, results) {
  let sheet = ss.getSheetByName('Push Results');
  if (!sheet) sheet = ss.insertSheet('Push Results');
  sheet.clear();
  
  const headers = ['Timestamp', 'Product ID', 'Handle', 'Status', 'Details'];
  sheet.getRange(1, 1, 1, headers.length).setValues([headers]).setFontWeight('bold').setBackground('#e8e8e8');
  
  const now = new Date();
  const rows = results.map(r => [now, r.productId, r.handle, r.status, r.details]);
  if (rows.length > 0) {
    sheet.getRange(2, 1, rows.length, headers.length).setValues(rows);
  }
  
  for (let i = 1; i <= headers.length; i++) sheet.autoResizeColumn(i);
}

// ── DRY RUN FROM MENU ──────────────────────────────────────

function dryRunPush() {
  try {
    const result = executePush(true);
    const a = result.analysis;
    
    let msg = `DRY RUN RESULTS\n\n`;
    msg += `Push tab rows: ${a.totalPushRows}\n`;
    msg += `Products with changes: ${a.productsWithChanges}\n`;
    msg += `Total field changes: ${a.totalChanges}\n`;
    msg += `Data was pulled at: ${a.pullTimestamp}\n\n`;
    
    if (a.changes.length > 0) {
      msg += `CHANGES DETECTED:\n\n`;
      a.changes.slice(0, 10).forEach(c => {
        msg += `${c.handle}:\n`;
        c.changes.forEach(ch => {
          const oldVal = ch.oldValue.substring(0, 30) || '(empty)';
          const newVal = ch.newValue.substring(0, 30) || '(empty)';
          msg += `  ${ch.field}: "${oldVal}" → "${newVal}"\n`;
        });
        msg += '\n';
      });
      if (a.changes.length > 10) {
        msg += `... and ${a.changes.length - 10} more products.\n`;
      }
    }
    
    SpreadsheetApp.getUi().alert(msg);
  } catch (e) {
    SpreadsheetApp.getUi().alert('❌ ' + e.message);
  }
}

// ── PUSH VARIANT PRICE ──────────────────────────────────────

function pushVariantPrice_(token, config, productId, variantId, newPrice) {
  var query = '\
    mutation VariantPriceUpdate($productId: ID!, $variants: [ProductVariantsBulkInput!]!) {\
      productVariantsBulkUpdate(productId: $productId, variants: $variants) {\
        productVariants {\
          id\
          price\
        }\
        userErrors {\
          field\
          message\
        }\
      }\
    }\
  ';
  
  var variables = {
    productId: productId,
    variants: [{
      id: variantId,
      price: newPrice.toString()
    }]
  };
  
  try {
    var result = shopifyGraphQL_(token, config.shopDomain, query, variables);
    var userErrors = result.data && result.data.productVariantsBulkUpdate 
      ? result.data.productVariantsBulkUpdate.userErrors || [] : [];
    
    if (userErrors.length > 0) {
      return { 
        success: false, 
        error: userErrors.map(function(e) { return e.field + ': ' + e.message; }).join('; ')
      };
    }
    
    return { success: true };
  } catch (e) {
    return { success: false, error: e.message };
  }
}

