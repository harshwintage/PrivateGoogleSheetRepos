      const pct = Math.round((result.processed / result.total) * 100);
      html += '<div style="background:#e8e8e8; border-radius:8px; height:24px; margin-bottom:16px; overflow:hidden;">';
      html += '<div style="background:#1a1a1a; height:100%; width:' + pct + '%; border-radius:8px; transition:width 0.5s; display:flex; align-items:center; justify-content:center; color:#fff; font-size:11px; font-weight:600;">' + pct + '%</div>';
      html += '</div>';
      
      html += '<button class="btn btn-analyze" onclick="cancelPush()">⛔ Cancel Push</button>';
      
      setTimeout(pollPushStatus, 15000);
      
      el.innerHTML = html;
      return;
    }
    
    if (result.results) {
      const successes = result.results.filter(r => r.status.includes('✅'));
      const failures = result.results.filter(r => r.status.includes('❌'));
      
      if (failures.length === 0) {
        html += '<div class="success-box">✅ <strong>All ' + successes.length + ' products updated successfully!</strong><br>Check the "Push Results" tab for details. Do a fresh Pull to update the Data tab.</div>';
      } else {
        html += '<div class="warning-box">⚠️ <strong>' + successes.length + ' succeeded, ' + failures.length + ' failed.</strong><br>Check the "Push Results" tab for details.</div>';
      }
      
      html += '<div class="change-list">';
      result.results.slice(0, 20).forEach(function(r) {
        html += '<div class="change-item">';
        html += '<div class="change-handle">' + r.status + ' ' + escapeHtml(r.handle) + '</div>';
        html += '<div class="change-detail">' + escapeHtml(r.details) + '</div>';
        html += '</div>';
      });
      if (result.results.length > 20) {
        html += '<div style="text-align:center; padding:8px; color:#888; font-size:12px;">... and ' + (result.results.length - 20) + ' more. See "Push Results" tab.</div>';
      }
      html += '</div>';
    } else {
      html += '<div class="info-box">' + escapeHtml(result.message) + '</div>';
    }
    
    html += '<button class="btn btn-analyze" onclick="analyze()">🔍 Analyze Again</button>';
    el.innerHTML = html;
  }
  
  function pollPushStatus() {
    google.script.run
      .withSuccessHandler(function(status) {
        if (!status.running) {
          onPushComplete({ success: true, results: status.results, inProgress: false });
          return;
        }
        
        const el = document.getElementById('results');
        const pct = Math.round((status.processed / status.total) * 100);
        const successes = status.results.filter(function(r) { return r.status.includes('✅'); }).length;
        const failures = status.results.filter(function(r) { return r.status.includes('❌'); }).length;
        
        let html = '<div class="info-box">🔄 <strong>Push in progress...</strong><br>' + status.processed + ' of ' + status.total + ' products processed.<br>' + successes + ' succeeded, ' + failures + ' failed so far.</div>';
        html += '<div style="background:#e8e8e8; border-radius:8px; height:24px; margin-bottom:16px; overflow:hidden;">';
        html += '<div style="background:#1a1a1a; height:100%; width:' + pct + '%; border-radius:8px; transition:width 0.5s; display:flex; align-items:center; justify-content:center; color:#fff; font-size:11px; font-weight:600;">' + pct + '%</div>';
        html += '</div>';
        html += '<button class="btn btn-analyze" onclick="cancelPush()">⛔ Cancel Push</button>';
        
        el.innerHTML = html;
        
        setTimeout(pollPushStatus, 15000);
      })
      .withFailureHandler(function() {
        setTimeout(pollPushStatus, 15000);
      })
      .getPushStatus();
  }
  
  function cancelPush() {
    if (!confirm('Cancel the push? Products already updated will stay updated.')) return;
    google.script.run
      .withSuccessHandler(function(result) {
        document.getElementById('results').innerHTML = '<div class="warning-box">⛔ Push cancelled. Check "Push Results" tab for what was processed.</div><button class="btn btn-analyze" onclick="analyze()">🔍 Analyze Again</button>';
      })
      .withFailureHandler(onError)
      .cancelPush();
  }
  
  function onError(err) {
    document.getElementById('results').innerHTML = '<div class="error-box">❌ ' + escapeHtml(err.message) + '</div><button class="btn btn-analyze" onclick="analyze()">🔍 Try Again</button>';
  }
  
  function escapeHtml(str) {
    if (!str) return '';
    return String(str).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
  }
</script>

</body>
</html>`;
}

